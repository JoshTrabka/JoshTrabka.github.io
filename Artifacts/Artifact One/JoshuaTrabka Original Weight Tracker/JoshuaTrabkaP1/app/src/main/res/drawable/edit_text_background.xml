<?xml version="1.0" encoding="utf-8"?>
<!-- Defines a white background with rounded corners and a light gray stroke -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Use the color for input fields defined in your colors.xml -->
    <solid android:color="@color/input_field_background_off_white" />

    <!-- Rounded corners for modern aesthetics -->
    <corners android:radius="8dp" />

    <!-- A subtle border using your outline color -->
    <stroke
        android:width="1dp"
        android:color="@color/outline_light_gray" />
</shape>