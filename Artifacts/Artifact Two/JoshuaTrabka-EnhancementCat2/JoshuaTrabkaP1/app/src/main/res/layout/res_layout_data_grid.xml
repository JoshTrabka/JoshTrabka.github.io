<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/title_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_weight_history"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="@color/primary_teal"
        android:layout_marginBottom="16dp" />

    <!-- Goal Setting Area -->
    <LinearLayout
        android:id="@+id/goal_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/title_history"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_goal_weight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_goal_weight"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/button_set_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_set_goal"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>
<!-- Textview for Weight prediction -->
    <TextView
        android:id="@+id/text_prediction_display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/goal_area"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/prediction_insufficient_data"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@android:color/darker_gray"
        android:textStyle="italic" />

    <!-- RecyclerView Area for displaying weight history -->
    <TextView
        android:id="@+id/header_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_prediction_display"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="@string/header_date_weight_action"
        android:textStyle="bold"
        android:background="#E0E0E0"
        android:textColor="@android:color/black"
        android:visibility="gone"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_weight_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_label"
        android:layout_above="@+id/entry_area"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />


    <!-- Log New Entry Area -->
    <LinearLayout
        android:id="@+id/entry_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_new_entry"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/primary_teal"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_entry_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_entry_date"
                    android:inputType="date" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_entry_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_entry_weight"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <Button
            android:id="@+id/button_submit_entry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_submit_entry"
            style="@style/Widget.MaterialComponents.Button.Icon" />
    </LinearLayout>

</RelativeLayout>
